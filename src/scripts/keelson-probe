#!/usr/bin/env bash
# Kubernetes probe entry. Reads /keelson/work/status (written each loop tick
# by the keelson controller) and answers startup, readiness, or liveness.
#
#   startup    heartbeat fresh AND every watched-kind PID alive
#   readiness  every watched-kind PID alive
#   liveness   heartbeat fresh
#
# Exit 0 on pass, 1 on fail. No output on success; one log line on failure.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/log.bash
source "${SCRIPT_DIR}/lib/log.bash"
# shellcheck source=lib/status.bash
source "${SCRIPT_DIR}/lib/status.bash"

usage() {
    cat <<'USAGE'
Usage: keelson-probe <startup|readiness|liveness>

Exits 0 if the requested probe passes, 1 otherwise.
USAGE
}

probe_liveness() {
    local max_age=${KEELSON_HEARTBEAT_MAX_AGE:?KEELSON_HEARTBEAT_MAX_AGE required}
    if ! status_heartbeat_fresh "$max_age"; then
        log_error probe-liveness-fail max-age="$max_age" file="$KEELSON_STATUS_FILE" \
            msg="Liveness probe failed: status file '$KEELSON_STATUS_FILE' heartbeat is older than ${max_age}s."
        return 1
    fi
}

probe_readiness() {
    if ! status_all_watchers_alive; then
        log_error probe-readiness-fail file="$KEELSON_STATUS_FILE" \
            msg="Readiness probe failed: not all watcher PIDs in '$KEELSON_STATUS_FILE' are alive."
        return 1
    fi
}

probe_startup() {
    probe_liveness || return 1
    probe_readiness || return 1
}

main() {
    case "${1:-}" in
        startup)   probe_startup ;;
        readiness) probe_readiness ;;
        liveness)  probe_liveness ;;
        -h|--help) usage ;;
        *)         usage >&2; return 64 ;;
    esac
}

main "$@"
