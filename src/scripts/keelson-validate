#!/usr/bin/env bash
# Pre-flight validation. Exits 0 on success, 1 on any check failure.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/log.bash
source "${SCRIPT_DIR}/lib/log.bash"
# shellcheck source=lib/validate.bash
source "${SCRIPT_DIR}/lib/validate.bash"

usage() {
    cat <<'USAGE'
Usage: keelson-validate [--help]

Check Keelson's runtime configuration: required env vars, required binaries,
auth-mode helpers declared in registries.yaml, and writable work directory.

Reports every failure in one pass and exits non-zero if any check failed.
USAGE
}

main() {
    case "${1:-}" in
        -h|--help) usage; return 0 ;;
    esac
    validate_config
}

main "$@"
