#!/usr/bin/env bash
# Patch a single workload's container image. Used by the scanner; CLI usable.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/log.bash
source "${SCRIPT_DIR}/lib/log.bash"
# shellcheck source=lib/managedfields.bash
source "${SCRIPT_DIR}/lib/managedfields.bash"
# shellcheck source=lib/update.bash
source "${SCRIPT_DIR}/lib/update.bash"

usage() {
    cat <<'USAGE'
Usage: keelson-update-resource <kind> <namespace> <name> <container> <new-image>

Strategic-merge patch the named container's image on the named workload.
Supports Deployment, StatefulSet, DaemonSet, CronJob.
USAGE
}

main() {
    case "${1:-}" in
        -h|--help) usage; return 0 ;;
    esac
    if [ $# -lt 5 ]; then
        usage >&2
        return 64
    fi

    update_apply "$1" "$2" "$3" "$4" "$5"
}

main "$@"
